# Copy this file to .env.alerts and fill in your values
# cp .env.alerts.example .env.alerts

# Comma-separated email addresses (for fail/complete alerts)
ALERT_EMAILS="you@example.com,professor@example.com"

# Discord webhook for ALERTS channel (fail, stall, complete, start)
DISCORD_ALERTS="https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN"

# Discord webhook for TRAINING UPDATES channel (progress every ~10 min)
DISCORD_UPDATES="https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN"
